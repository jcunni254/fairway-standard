# The Fairway Standard — Environment Variables
# Copy this file to .env.local and fill in your keys. Never commit .env.local.

# Clerk (https://dashboard.clerk.com → API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Supabase (https://supabase.com/dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Mapbox (https://account.mapbox.com/access-tokens/)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Resend (https://resend.com/api-keys)
RESEND_API_KEY=

# PostHog (https://app.posthog.com → Project Settings)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Sentry (https://sentry.io → Project Settings → DSN)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# OpenAI (for interview transcription)
OPENAI_API_KEY=

# App
NEXT_PUBLIC_APP_URL=https://thefairwaystandard.org
ADMIN_USER_IDS=
